{
  "name": "agent_city_frontend",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:clean": "node -e \"const fs=require('fs'); if (fs.existsSync('.next')) fs.rmSync('.next',{recursive:true,force:true});\" && next build",
    "start": "next start -p 3000",
    "lint": "next lint",
    "e2e": "playwright test",
    "e2e:app": "npm run build && playwright test -c playwright.app.config.ts",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "screenshots:app": "node scripts/capture-ui-screenshots.js"
  },
  "dependencies": {
    "@react-three/drei": "^9.112.0",
    "@react-three/fiber": "^8.16.8",
    "clsx": "^2.1.1",
    "next": "^14.2.14",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.167.1",
    "zustand": "^4.5.5",
    "@tauri-apps/api": "^1.5.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@types/node": "^20.16.9",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.2"
  }
}
